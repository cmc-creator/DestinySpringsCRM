# Database
DATABASE_URL="postgresql://user:password@host:5432/destinysprings?sslmode=require"

# NextAuth
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://your-production-domain.com"

# Resend (Email)
RESEND_API_KEY="re_..."
# Must be a verified sender domain in your Resend account (not onboarding@resend.dev)
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# Brand (White-Label)
NEXT_PUBLIC_ORG_NAME="Destiny Springs CRM"
NEXT_PUBLIC_ORG_WEBSITE="https://destinyspringshealthcare.com"
NEXT_PUBLIC_ORG_EMAIL="ops@destinyspringshealthcare.com"
NEXT_PUBLIC_ORG_TAGLINE="Behavioral Health CRM"

# Admin bootstrap - used to create first admin account on fresh deploy
# GET /api/admin/bootstrap?secret=BOOTSTRAP_SECRET to create the hardcoded admin user
# POST /api/admin/bootstrap with { secret, email, name, password } to create a custom admin
BOOTSTRAP_SECRET="your-bootstrap-secret-change-this"
BOOTSTRAP_PASSWORD="your-bootstrap-password-change-this"

# Cron jobs (Vercel will call /api/cron/* with this in Authorization header)
CRON_SECRET="your-cron-secret"

# Seed script (dev only)
SEED_SECRET="your-seed-secret-change-this"

# AI Assistant (Aegis) - uses Google Gemini
GEMINI_API_KEY="your-gemini-api-key"

# Monday.com integration (optional - enables BD rep lookup on signup)
MONDAY_API_KEY="your-monday-api-key"
MONDAY_BD_BOARD_ID="your-board-id"

# Resend webhook secret (optional - for email open tracking integration)
RESEND_WEBHOOK_SECRET="your-resend-webhook-secret"

# Sentry (optional but recommended for production error monitoring)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"
NEXT_PUBLIC_SENTRY_REPLAY_SESSION_SAMPLE_RATE="0"
NEXT_PUBLIC_SENTRY_REPLAY_ERROR_SAMPLE_RATE="1"

# Sentry release artifacts (for sourcemaps upload in CI)
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
