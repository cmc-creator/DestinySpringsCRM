// Destiny Springs Healthcare CRM — Behavioral Health Admission & Referral Management
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// WHITE-LABEL ORGANIZATION
// ─────────────────────────────────────────

model Organization {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  logoUrl         String?
  faviconUrl      String?
  primaryColor    String   @default("#00d4ff")
  accentColor     String   @default("#fbbf24")
  customDomain    String?  @unique
  supportEmail    String?
  stripeAccountId String?
  planTier        String   @default("starter")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users User[]

  @@map("organizations")
}

// ─────────────────────────────────────────
// AUTH / USERS
// ─────────────────────────────────────────

enum Role {
  ADMIN
  REP
  ACCOUNT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(ACCOUNT)
  preferences   Json?
  twoFactorSecret String?
  twoFactorEnabled Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  accounts  Account[]
  sessions  Session[]

  rep       Rep?
  hospital  Hospital?

  createdActivities Activity[] @relation("ActivityCreatedBy")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────
// BD REPS (replaces Pilots)
// ─────────────────────────────────────────

enum RepStatus {
  ACTIVE
  INACTIVE
  PENDING_REVIEW
  SUSPENDED
}

model Rep {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone        String?
  city         String?
  state        String?
  zip          String?
  bio          String?
  title        String?
  territory    String?

  // Healthcare credentials
  hipaaTrainedAt   DateTime?
  hipaaDocUrl      String?
  licensedStates   String[]

  // Business info
  businessName  String?
  w9OnFile      Boolean  @default(false)
  w9DocUrl      String?

  // Operational
  status  RepStatus @default(PENDING_REVIEW)
  rating  Float?
  notes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  territories     RepTerritory[]
  opportunities   Opportunity[]
  complianceDocs  ComplianceDoc[]
  payments        RepPayment[]
  contracts       Contract[]
  activities      Activity[]
  reviews         RepReview[]
  availability    RepAvailability[]
  w9Form          W9Form?
  leads           Lead[]
  referralSources ReferralSource[]

  @@map("reps")
}

model RepTerritory {
  id      String @id @default(cuid())
  repId   String
  rep     Rep    @relation(fields: [repId], references: [id], onDelete: Cascade)
  state   String
  city    String?
  region  String?
  notes   String?
  createdAt DateTime @default(now())

  @@map("rep_territories")
}

model RepAvailability {
  id        String   @id @default(cuid())
  repId     String
  rep       Rep      @relation(fields: [repId], references: [id], onDelete: Cascade)
  date      DateTime
  available Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())

  @@map("rep_availability")
}

model RepReview {
  id        String   @id @default(cuid())
  repId     String
  rep       Rep      @relation(fields: [repId], references: [id], onDelete: Cascade)
  rating    Float
  comment   String?
  reviewedBy String?
  createdAt DateTime @default(now())

  @@map("rep_reviews")
}

// ─────────────────────────────────────────
// SENDING FACILITIES (Account portal users)
// ─────────────────────────────────────────

enum HospitalStatus {
  ACTIVE
  INACTIVE
  PROSPECT
  CHURNED
}

enum HospitalType {
  EMERGENCY_DEPARTMENT       // Hospital ED — primary referral channel
  INPATIENT_MEDICAL          // Medical inpatient — psych consult referrals
  PRIMARY_CARE               // PCP / family medicine office
  OUTPATIENT_PSYCHIATRY      // Outpatient psych / counseling practice
  IOP_PHP                    // IOP / PHP step-up referrals
  CRISIS_STABILIZATION_UNIT  // CSU / mobile crisis
  CRISIS_LINE                // Crisis hotline services
  COURT_LEGAL                // Court-ordered treatment / DCS / probation
  COMMUNITY_MENTAL_HEALTH    // FQHC / community behavioral health
  SCHOOL_COUNSELOR           // School-based counseling
  PEER_SUPPORT               // Peer support organizations
  SNF_LTACH                  // Skilled nursing / LTACH
  SELF_REFERRAL              // Patient or family self-referral
  OTHER
}

model Hospital {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  hospitalName   String
  systemName     String?
  hospitalType   HospitalType @default(OTHER)
  npi            String?
  taxId          String?

  // Size & capabilities
  bedCount       Int?
  annualRevenue  Decimal?
  serviceLines   String[]

  // Primary contact
  primaryContactName  String?
  primaryContactTitle String?
  primaryContactEmail String?
  primaryContactPhone String?

  // Address
  address String?
  city    String?
  state   String?
  zip     String?

  // BD relationship
  status         HospitalStatus @default(PROSPECT)
  assignedRepId  String?
  contractValue  Decimal?
  notes          String?
  source         String?
  metadata       Json?

  // Portal credentials
  portalPassword String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts      Contact[]
  opportunities Opportunity[]
  invoices      Invoice[]
  contracts     Contract[]
  activities    Activity[]
  leads         Lead[]

  @@map("hospitals")
}

// ─────────────────────────────────────────
// CONTACTS (Hospital decision makers)
// ─────────────────────────────────────────

enum ContactType {
  CMO
  CFO
  CNO
  CEO
  COO
  DEPARTMENT_HEAD
  PHYSICIAN_CHAMPION
  VP_BUSINESS_DEVELOPMENT
  DIRECTOR
  COORDINATOR
  // BH-specific referral contact roles
  SOCIAL_WORKER
  ED_PHYSICIAN
  PRIMARY_CARE_PHYSICIAN
  COURT_LIAISON
  CRISIS_COUNSELOR
  CASE_MANAGER
  DISCHARGE_PLANNER
  THERAPIST
  PSYCHIATRIST
  OTHER
}

model Contact {
  id         String @id @default(cuid())
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  name       String
  title      String?
  type       ContactType @default(OTHER)
  email      String?
  phone      String?
  department String?
  isPrimary  Boolean @default(false)
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities Activity[]

  @@map("contacts")
}

// ─────────────────────────────────────────
// INQUIRIES (Prospective referral source cultivation)
// ─────────────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATING
  WON
  LOST
  UNQUALIFIED
}

enum LeadSource {
  REFERRAL
  COLD_OUTREACH
  CONFERENCE
  INBOUND
  LINKEDIN
  WEBINAR
  EXISTING_RELATIONSHIP
  OTHER
}

model Lead {
  id           String @id @default(cuid())
  hospitalName String
  systemName   String?
  hospitalType HospitalType?
  bedCount     Int?
  state        String?
  city         String?

  contactName  String?
  contactEmail String?
  contactPhone String?
  contactTitle String?

  serviceInterest String?
  estimatedValue  Decimal?
  notes           String?

  status  LeadStatus @default(NEW)
  source  LeadSource @default(OTHER)
  priority String    @default("MEDIUM")
  nextFollowUp DateTime?
  metadata     Json?

  assignedRepId String?
  assignedRep   Rep?   @relation(fields: [assignedRepId], references: [id])

  hospitalId String?
  hospital   Hospital? @relation(fields: [hospitalId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities Activity[]

  @@map("leads")
}

// ─────────────────────────────────────────
// ADMISSIONS PIPELINE
// ─────────────────────────────────────────

enum OpportunityStage {
  INQUIRY           // Initial referral or admission inquiry received
  CLINICAL_REVIEW   // Clinical team assessing appropriateness for admission
  INSURANCE_AUTH    // Awaiting insurance / AHCCCS authorization
  ADMITTED          // Patient has been admitted
  ACTIVE            // Currently inpatient
  DISCHARGED        // Stay complete — aftercare / discharge planning
  DECLINED          // Clinical decline, no bed, or out-of-network
  ON_HOLD           // Holding for bed availability or external factor
}

enum ServiceLine {
  ADULT_INPATIENT_PSYCH     // Adult acute inpatient psychiatry
  ADOLESCENT_PSYCH          // Adolescent inpatient psychiatry (ages 13–17)
  GERIATRIC_PSYCH           // Older adult / geriatric psychiatry
  DUAL_DIAGNOSIS            // Co-occurring mental health & substance use
  DETOX_STABILIZATION       // Medical detox / withdrawal stabilization
  CRISIS_STABILIZATION      // Short-term crisis stabilization / 23-hr obs
  PARTIAL_HOSPITALIZATION   // PHP — structured day treatment program
  INTENSIVE_OUTPATIENT      // IOP — step-down / step-up care
  OUTPATIENT_THERAPY        // Outpatient individual / group therapy
  MED_MGMT                  // Medication management / outpatient psychiatry
  COURT_ORDERED_TREATMENT   // AOT / court-ordered treatment (ARS §36-540)
  OTHER
}

model Opportunity {
  id          String @id @default(cuid())
  title       String
  description String?

  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id])

  assignedRepId String?
  assignedRep   Rep?    @relation(fields: [assignedRepId], references: [id])

  stage        OpportunityStage @default(INQUIRY)
  serviceLine  ServiceLine      @default(OTHER)
  value        Decimal?
  closeDate    DateTime?
  priority     String   @default("MEDIUM")

  // BH admission-specific fields
  admissionType AdmissionType?
  payorId       String?
  payor         Payor?         @relation(fields: [payorId], references: [id])
  estimatedLOS  Int?           // Estimated length of stay (days)

  notes       String?
  lostReason  String?
  nextFollowUp DateTime?
  metadata     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities Activity[]
  invoices   Invoice[]
  contracts  Contract[]

  @@map("opportunities")
}

// ─────────────────────────────────────────
// INVOICES
// ─────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

model Invoice {
  id          String @id @default(cuid())
  invoiceNumber String @unique
  hospitalId  String
  hospital    Hospital @relation(fields: [hospitalId], references: [id])

  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  status      InvoiceStatus @default(DRAFT)
  totalAmount Decimal
  dueDate     DateTime?
  paidAt      DateTime?
  notes       String?
  lineItems   Json?

  stripePaymentIntentId String?
  stripeInvoiceId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("invoices")
}

// ─────────────────────────────────────────
// CONTRACTS
// ─────────────────────────────────────────

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  ACTIVE
  EXPIRED
  TERMINATED
}

model Contract {
  id         String @id @default(cuid())
  title      String
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id])

  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  assignedRepId String?
  assignedRep   Rep?    @relation(fields: [assignedRepId], references: [id])

  status     ContractStatus @default(DRAFT)
  startDate  DateTime?
  endDate    DateTime?
  value      Decimal?
  terms      String?
  fileUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contracts")
}

// ─────────────────────────────────────────
// COMPLIANCE DOCUMENTS
// ─────────────────────────────────────────

enum ComplianceDocType {
  HIPAA_TRAINING
  STATE_LICENSE
  NDA
  BAA
  MSA
  W9
  INSURANCE
  BACKGROUND_CHECK
  OTHER
}

model ComplianceDoc {
  id      String @id @default(cuid())
  repId   String
  rep     Rep    @relation(fields: [repId], references: [id], onDelete: Cascade)

  type       ComplianceDocType
  title      String
  fileUrl    String?
  expiresAt  DateTime?
  verified   Boolean @default(false)
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("compliance_docs")
}

// ─────────────────────────────────────────
// ACTIVITIES (CRM activity log)
// ─────────────────────────────────────────

enum ActivityType {
  CALL
  EMAIL
  NOTE
  MEETING
  LUNCH
  TASK
  PROPOSAL_SENT
  CONTRACT_SENT
  DEMO_COMPLETED
  SITE_VISIT
  CONFERENCE
  FOLLOW_UP
  // BH liaison-specific activity types
  IN_SERVICE          // In-service training / education at referral source
  FACILITY_TOUR       // Tour of Destiny Springs for referral source staff
  CE_PRESENTATION     // Continuing education / CME presentation
  CRISIS_CONSULT      // Crisis consultation / evaluation call
  LUNCH_AND_LEARN     // Lunch-and-learn at referral source
  COMMUNITY_EVENT     // Community outreach event
  REFERRAL_RECEIVED   // Formal referral received
  DISCHARGE_PLANNING  // Discharge / aftercare coordination with referral source
}

model Activity {
  id    String @id @default(cuid())
  type  ActivityType
  title String
  notes String?

  repId String?
  rep   Rep?   @relation(fields: [repId], references: [id])

  hospitalId String?
  hospital   Hospital? @relation(fields: [hospitalId], references: [id])

  leadId String?
  lead   Lead?  @relation(fields: [leadId], references: [id])

  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  referralSourceId String?
  referralSource   ReferralSource? @relation(fields: [referralSourceId], references: [id])

  scheduledAt DateTime?
  completedAt DateTime?

  createdByUserId String?
  createdByUser   User?   @relation("ActivityCreatedBy", fields: [createdByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("activities")
}

// ─────────────────────────────────────────
// REP PAYMENTS
// ─────────────────────────────────────────

enum RepPaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

model RepPayment {
  id     String @id @default(cuid())
  repId  String
  rep    Rep    @relation(fields: [repId], references: [id], onDelete: Cascade)

  amount      Decimal
  description String?
  status      RepPaymentStatus @default(PENDING)
  paidAt      DateTime?
  periodStart DateTime?
  periodEnd   DateTime?

  stripeTransferId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rep_payments")
}

// ─────────────────────────────────────────
// W-9 FORMS
// ─────────────────────────────────────────

model W9Form {
  id     String @id @default(cuid())
  repId  String @unique
  rep    Rep    @relation(fields: [repId], references: [id], onDelete: Cascade)

  legalName     String
  businessName  String?
  taxClassification String?
  ein           String?
  ssn           String?
  address       String?
  city          String?
  state         String?
  zip           String?
  signedAt      DateTime?
  fileUrl       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("w9_forms")
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id        String  @id @default(cuid())
  userId    String
  title     String
  body      String?
  type      String  @default("INFO")
  read      Boolean @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@map("notifications")
}

// ─────────────────────────────────────────
// MESSAGES / CHAT
// ─────────────────────────────────────────

model Message {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  body       String
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@map("messages")
}

// ─────────────────────────────────────────
// INTEGRATION TOKENS (per-user OAuth)
// ─────────────────────────────────────────

model IntegrationToken {
  id           String    @id @default(cuid())
  userId       String
  provider     String    // "microsoft" | "google"
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?
  scope        String?
  email        String?
  displayName  String?
  teamsWebhook String?   // Teams incoming webhook URL (optional)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, provider])
  @@map("integration_tokens")
}

// ─────────────────────────────────────────
// COMMUNICATIONS LOG
// ─────────────────────────────────────────

enum CommChannel {
  OUTLOOK
  GMAIL
  TEAMS
  INTERNAL
}

enum CommStatus {
  DRAFT
  SENT
  FAILED
  SCHEDULED
}

enum CommCategory {
  FOLLOW_UP
  INTRODUCTION
  PROPOSAL
  CHECK_IN
  THANK_YOU
  INVITATION
  OTHER
}

model CommunicationLog {
  id          String      @id @default(cuid())
  fromUserId  String
  toEmail     String?
  toName      String?
  subject     String?
  body        String      @db.Text
  channel     CommChannel @default(INTERNAL)
  status      CommStatus  @default(DRAFT)
  externalId  String?     // Provider message ID
  scheduledAt DateTime?
  sentAt      DateTime?

  hospitalId    String?
  leadId        String?
  opportunityId String?
  contactId     String?
  templateId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("communication_logs")
}

// ─────────────────────────────────────────
// COMMUNICATION TEMPLATES
// ─────────────────────────────────────────

model CommunicationTemplate {
  id          String       @id @default(cuid())
  name        String
  subject     String?
  body        String       @db.Text
  category    CommCategory @default(OTHER)
  createdById String?
  isGlobal    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("communication_templates")
}

// ─────────────────────────────────────────
// REFERRAL TRACKING (MedWorxs integration)
// ─────────────────────────────────────────

enum ReferralSourceType {
  EMERGENCY_DEPARTMENT       // ED / hospital emergency department
  PRIMARY_CARE_PHYSICIAN     // PCP / family medicine
  PSYCHIATRIST               // Outpatient psychiatrist
  OUTPATIENT_THERAPIST       // Licensed therapist / counselor
  IOP_PHP_PROGRAM            // IOP or PHP program (step-up referrals)
  CRISIS_STABILIZATION_UNIT  // CSU / mobile crisis team
  CRISIS_LINE                // Crisis hotline
  COURT_LEGAL_SYSTEM         // Courts / DCS / probation / AOT program
  COMMUNITY_MENTAL_HEALTH    // FQHC / community behavioral health center
  SNF_LTACH                  // Skilled nursing / long-term acute care
  SCHOOL_COUNSELOR           // School-based counseling
  PEER_SUPPORT               // Peer support organizations / recovery networks
  SELF_REFERRAL              // Patient or family walk-in / self-referral
  OTHER
}

enum ReferralStatus {
  RECEIVED
  ADMITTED
  DECLINED
  PENDING
  DUPLICATE
}

enum IntegrationMethod {
  CSV
  HL7
  FHIR
  MANUAL
}

model ReferralSource {
  id           String             @id @default(cuid())
  name         String
  type         ReferralSourceType @default(OTHER)
  specialty    String?
  practiceName String?
  npi          String?

  contactName  String?
  email        String?
  phone        String?

  address      String?
  city         String?
  state        String?
  zip          String?

  assignedRepId String?
  assignedRep   Rep?   @relation(fields: [assignedRepId], references: [id])

  monthlyGoal  Int?
  notes        String?
  active       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referrals Referral[]
  activities Activity[]

  @@map("referral_sources")
}

model Referral {
  id               String         @id @default(cuid())
  referralSourceId String
  referralSource   ReferralSource @relation(fields: [referralSourceId], references: [id])

  patientInitials String?
  admissionDate   DateTime?
  dischargeDate   DateTime?
  serviceLine     String?
  externalId      String?   // MedWorxs encounter/patient ID to prevent duplicates
  importId        String?   // links back to MedworxsImport

  status ReferralStatus @default(RECEIVED)
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([referralSourceId, externalId]) // prevent duplicate imports
  @@map("referrals")
}

model IntegrationConfig {
  id      String            @id @default(cuid())
  name    String
  method  IntegrationMethod
  enabled Boolean           @default(false)
  config  Json?
  secret  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  imports MedworxsImport[]

  @@unique([name, method])
  @@map("integration_configs")
}

model MedworxsImport {
  id            String            @id @default(cuid())
  integrationId String
  integration   IntegrationConfig @relation(fields: [integrationId], references: [id])

  method     IntegrationMethod
  filename   String?
  totalRows  Int               @default(0)
  imported   Int               @default(0)
  skipped    Int               @default(0)
  errors     Int               @default(0)
  errorLog   Json?
  importedBy String?

  createdAt DateTime @default(now())

  @@map("medworxs_imports")
}

// ─────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  userEmail  String?
  userName   String?
  action     String   // "CREATE" | "UPDATE" | "DELETE"
  resource   String   // "Lead" | "Opportunity" | "Hospital" etc
  resourceId String?
  diff       Json?    // { before, after } snapshot
  ip         String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

// ─────────────────────────────────────────
// ARIZONA BH — ADMISSION TYPE
// ─────────────────────────────────────────

enum AdmissionType {
  VOLUNTARY              // Patient voluntarily agrees to admit
  TITLE_36_EMERGENCY     // ARS §36-520 — Arizona emergency psychiatric hold
  COURT_ORDERED          // Court-Ordered Treatment (COT) under ARS §36-540
  CONDITIONAL_RELEASE    // Conditional release from prior court-ordered treatment
  MINOR_PARENTAL_CONSENT // Minor admitted with parental / guardian consent
}

// ─────────────────────────────────────────
// INSURANCE PAYORS
// ─────────────────────────────────────────

enum PayorType {
  COMMERCIAL
  MEDICARE
  MEDICAID
  MEDICARE_ADVANTAGE
  TRICARE
  AHCCCS              // Arizona Health Care Cost Containment System (AZ Medicaid)
  SELF_PAY
  OTHER
}

model Payor {
  id              String    @id @default(cuid())
  name            String
  type            PayorType @default(COMMERCIAL)
  planName        String?
  phone           String?   // Member services line
  authPhone       String?   // Utilization review / prior auth line
  fax             String?
  website         String?
  inNetwork       Boolean   @default(true)
  requiresPreAuth Boolean   @default(true)
  avgAuthDays     Int?      // Average days to obtain authorization
  notes           String?
  active          Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opportunities Opportunity[]

  @@map("payors")
}

// ─────────────────────────────────────────
// DAILY CENSUS SNAPSHOTS
// ─────────────────────────────────────────

model CensusSnapshot {
  id   String   @id @default(cuid())
  date DateTime @unique // One snapshot per calendar day

  // Adult Inpatient Psychiatry unit
  adultTotal      Int @default(0)
  adultAvailable  Int @default(0)

  // Adolescent Psychiatry unit
  adolescentTotal      Int @default(0)
  adolescentAvailable  Int @default(0)

  // Geriatric / Older Adult unit
  geriatricTotal      Int @default(0)
  geriatricAvailable  Int @default(0)

  // Dual Diagnosis / Co-occurring unit
  dualDxTotal      Int @default(0)
  dualDxAvailable  Int @default(0)

  note      String?
  createdAt DateTime @default(now())

  @@map("census_snapshots")
}
